class Solution:
    def sumAndMultiply(self, s: str, queries: List[List[int]]) -> List[int]:
        MOD = 10 ** 9 + 7
        n = len(s)
        pos = []
        digits = []
        for i, ch in enumerate(s):
            if ch != '0':
                pos.append(i)
                digits.append(int(ch))
        k = len(pos)
        if k == 0:
            return [0] * len(queries)
        prefix_sum = [0] * (k + 1)
        for i in range(k):
            prefix_sum[i + 1] = prefix_sum[i] + digits[i]
        pow10 = [1] * (k + 1)
        for i in range(1, k + 1):
            pow10[i] = (pow10[i - 1] * 10) % MOD
        prefix_hash = [0] * (k + 1)
        for i in range(k):
            prefix_hash[i + 1] = (prefix_hash[i] * 10 + digits[i]) % MOD
        ans = []
        for l, r in queries:
            left = bisect_left(pos, l)
            right = bisect_right(pos, r)
            if left == right:
                ans.append(0)
                continue
            length = right - left
            x = (
                prefix_hash[right]
                - prefix_hash[left] * pow10[length]
            ) % MOD
            digit_sum = prefix_sum[right] - prefix_sum[left]
            ans.append((x * digit_sum) % MOD)
        return ans
